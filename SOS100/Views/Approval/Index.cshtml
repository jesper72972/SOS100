@model List<SOS100.Models.Approval>

@{
    ViewData["Title"] = "Hantera ansökningar";
}

<link rel="stylesheet" href="~/css/approval.css" />

<div class="approval-page">
    <h2>Hantera ansökningar</h2>
    <p class="approval-description">
        Här kan HR granska inkomna ansökningar, skriva en kommentar och sedan godkänna eller neka.
    </p>

    @if (ViewBag.Error != null)
    {
        <p style="color:red;">@ViewBag.Error</p>
    }

    @if (Model == null || !Model.Any())
    {
        <div class="empty-message">
            Det finns inga ansökningar att visa just nu.
        </div>
    }
    else
    {
        <table class="approval-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Ansöknings-ID</th>
                    <th>Godkännare</th>
                    <th>Status</th>
                    <th>Nuvarande kommentar</th>
                    <th>Beslutsdatum</th>
                    <th>Ny kommentar</th>
                    <th>Åtgärd</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var approval in Model)
            {
                var statusClass = approval.Decision == "Approved"
                    ? "status-approved"
                    : approval.Decision == "Rejected"
                        ? "status-rejected"
                        : "status-pending";

                <tr>
                    <td>@approval.Id</td>
                    <td>@approval.ApplicationId</td>
                    <td>@approval.ApproverId</td>
                    <td class="@statusClass">@approval.Decision</td>
                    <td>@approval.Comment</td>
                    <td>@approval.DecisionDate</td>
                    <td>
                        <input form="form-@approval.Id"
                               class="comment-input"
                               type="text"
                               name="comment"
                               placeholder="Skriv kommentar" />
                    </td>
                    <td>
                        <form id="form-@approval.Id" method="post" class="action-form">
                            <input type="hidden" name="id" value="@approval.Id" />

                            <button type="submit"
                                    class="btn-approve"
                                    asp-controller="Approval"
                                    asp-action="Approve">
                                Godkänn
                            </button>

                            <button type="submit"
                                    class="btn-reject"
                                    asp-controller="Approval"
                                    asp-action="Reject">
                                Neka
                            </button>
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>
