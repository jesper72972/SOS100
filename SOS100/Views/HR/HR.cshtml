<head>
    <title></title>
</head>

<body>
<a asp-controller="Account" asp-action="SignOutUser">Log out</a>
<p>Create a benefit</p>

<form   asp-action="Create"> 
   
    Titel <br/>
    <input asp-for="Title"/> <br/>
    Kategorie:  <br/>
    <input asp-for="categorie"/> <br/>
    Beskrivning: <br/>
    <input asp-for="Description"/> <br/>
