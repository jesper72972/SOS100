    Kategorie:  <br/>
    <input asp-for="categorie"/> <br/>
    Beskrivning: <br/>
    <input asp-for="Description"/> <br/>
    <input type="submit"  value="Edit"/>
</form>

<p>Radera en personalförmån:</p>

<form  asp-action="Delete">
    ID: <br/>
    <input asp-for="ID"/> <br/> 
    <input type="submit" value="Delete"/>
</form>


