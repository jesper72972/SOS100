@section Scripts {
    <script>
        function showPanel(type) {
            document.getElementById('user-panel').style.display = 'none';
            document.getElementById('admin-panel').style.display = 'none';
            document.getElementById(type + '-panel').style.display = 'block';
        }

        // Auto-open user panel if a name filter is active
        @if (!string.IsNullOrEmpty(Model.SelectedName))
        {
            <text>document.addEventListener('DOMContentLoaded', () => showPanel('user'));</text>
        }
    </script>
}
