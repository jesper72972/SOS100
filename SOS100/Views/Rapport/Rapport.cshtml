@model SOS100.Models.RapportStatistik

@{
    ViewData["Title"] = "Rapport och statistik";
}

<h1>Rapport och statistik</h1>

<div class="mb-4">
    <p><strong>Totalt antal förmåner:</strong> @Model.TotaltAntalFormaner</p>
    <p><strong>Totalt antal ansökningar:</strong> @Model.TotaltAntalAnsokningar</p>
    <p><strong>Totalt antal godkända:</strong> @Model.TotaltAntalGodkanda</p>
</div>

<h2>Statistik per förmån</h2>

<table class="table">
    <thead>
    <tr>
        <th>Förmån</th>
        <th>Kategori</th>
        <th>Antal ansökningar</th>
        <th>Antal godkända</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var forman in Model.StatistikPerForman)
    {
        <tr>
            <td>@forman.Namn</td>
            <td>@forman.Kategori</td>
            <td>@forman.AntalAnsokningar</td>
            <td>@forman.AntalGodkanda</td>
        </tr>
    }
    </tbody>
</table>